# Server Configuration (used by both vLLM and llama-cpp-python)
VLLM_MODEL="your-org/your-model-name"
VLLM_HOST="0.0.0.0"
VLLM_PORT=8000

# llama-cpp-python: path to GGUF file (used by llama_cpp_server.sh)
# GGUF_MODEL_PATH="/path/to/your/model.gguf"

# HuggingFace token (uncomment if using a gated model)
# HUGGING_FACE_HUB_TOKEN=hf_your_token_here
